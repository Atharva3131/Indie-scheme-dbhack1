# Government Scheme Copilot Configuration
# Copy this file to .env and update values as needed

# Application Settings
SCHEME_APP_NAME=Government Scheme Copilot
SCHEME_APP_VERSION=1.0.0
SCHEME_DEBUG=false
SCHEME_LOG_LEVEL=INFO

# Server Configuration
SCHEME_HOST=0.0.0.0
SCHEME_PORT=8000
SCHEME_RELOAD=false
SCHEME_WORKERS=1

# API Settings
SCHEME_API_PREFIX=/api
SCHEME_CORS_ORIGINS=["*"]
SCHEME_MAX_REQUEST_SIZE=1048576

# External Services Configuration
SCHEME_SARVAM_API_KEY=sk_s3685mrt_I1bEdMa8d7I2H3EQz5hM0Yzj
SCHEME_SARVAM_BASE_URL=https://api.sarvam.ai
SCHEME_ENABLE_TRANSLATION=true
SCHEME_ENABLE_LLM_RESPONSES=true
SCHEME_EXTERNAL_SERVICE_TIMEOUT=10

# Search Configuration
SCHEME_SIMILARITY_THRESHOLD=0.3
SCHEME_MAX_SEARCH_RESULTS=10
SCHEME_EMBEDDING_DIMENSIONS=384
SCHEME_ENABLE_SEMANTIC_SEARCH=true

# Language Settings
SCHEME_DEFAULT_LANGUAGE=english
SCHEME_SUPPORTED_LANGUAGES=["english","hindi"]

# Performance Settings
SCHEME_CACHE_SIZE=1000
SCHEME_CACHE_TTL=3600
SCHEME_REQUEST_TIMEOUT=30
SCHEME_MAX_CONCURRENT_REQUESTS=100

# Data Settings
SCHEME_SCHEMES_DATA_PATH=data/schemes.json
SCHEME_BACKUP_DATA_PATH=
SCHEME_DATA_VALIDATION_ENABLED=true

# Security Settings
SCHEME_ENABLE_RATE_LIMITING=true
SCHEME_RATE_LIMIT_REQUESTS=100
SCHEME_ENABLE_REQUEST_LOGGING=true